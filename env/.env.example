HOSTNAME=getouch.my
PUBLIC_IP=72.62.254.86
PROVIDER=Hostinger
OS_FAMILY=ubuntu-24.04

# Wave 1 access policy
DEPLOY_USER=deploy
DEPLOY_SSH_PUBLIC_KEY=ssh-ed25519 REPLACE_WITH_PUBLIC_KEY_COMMENT_ONLY

# DNS draft values
COOLIFY_DOMAIN=coolify.getouch.my
HOMEPAGE_DOMAIN=home.getouch.my
UPTIME_KUMA_DOMAIN=status.getouch.my

# Backup scaffold values
BACKUP_ROOT=/srv/backups
OFFSITE_TARGET_NAME=REPLACE_WITH_EXTERNAL_DESTINATION_REFERENCE

# PostgreSQL backup runtime placeholders
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=REPLACE_ME
POSTGRES_USER=REPLACE_ME
POSTGRES_PASSWORD=REPLACE_ME_AT_RUNTIME_ONLY

# Future services are documented only. Do not treat placeholders below as active scope.
SUPABASE_DOMAIN=supabase.getouch.my
